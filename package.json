{
  "name": "@amansanoj/brand",
  "version": "1.0.7",
  "description": "Personal brand system — shadcn/ui-compatible CSS tokens, Tailwind config, logos, fonts, headshots, and shared assets used across all my projects.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amansanoj/brand.git"
  },
  "module": "index.ts",
  "type": "module",
  "private": false,
  "exports": {
    ".": "./index.ts",
    "./tailwind": "./tailwind.config.ts",
    "./tokens": "./tokens.json",
    "./globals.css": "./globals.css",
    "./assets/*": "./assets/*",
    "./images/*": "./images/*"
  },
  "files": [
    "index.ts",
    "tailwind.config.ts",
    "tokens.json",
    "globals.css",
    "assets/",
    "images/"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
